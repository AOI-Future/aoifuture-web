{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoifuture.com/schemas/aoi-news-source-read-v1.schema.json",
  "title": "AOIFUTURE News private source-read receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "signal_id", "normalized_source_url", "source_kind", "read_at", "claim_locator", "reviewed_by", "approved_at", "decision"],
  "properties": {
    "schema_version": { "const": "aoi.news.source-read.v1" },
    "signal_id": { "$ref": "#/$defs/id" },
    "normalized_source_url": { "type": "string", "format": "uri", "pattern": "^https://" },
    "source_kind": { "enum": ["official", "documentation", "release", "repository", "paper", "advisory", "regulator", "original-reporting", "analysis"] },
    "read_at": { "type": "string", "format": "date-time" },
    "claim_locator": { "$ref": "#/$defs/text500" },
    "reviewed_by": { "$ref": "#/$defs/text100" },
    "approved_at": { "type": "string", "format": "date-time" },
    "decision": { "enum": ["approved", "rejected"] }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,79}$" },
    "text100": { "type": "string", "minLength": 3, "maxLength": 100, "pattern": "^[^<>]*$" },
    "text500": { "type": "string", "minLength": 8, "maxLength": 500, "pattern": "^[^<>]*$" }
  }
}
