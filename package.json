{
  "name": "aoifuture",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:tools": "playwright test tests/tools.spec.ts",
    "test:agent-security": "vitest run tests/agent-security-reference.test.ts",
    "test:agent-security:e2e": "playwright test tests/agent-security-reference.spec.ts",
    "test:intake": "vitest run tests/consultation-*.test.ts tests/notion-consultation.test.ts",
    "test:intake:e2e": "playwright test tests/consultation-intake.spec.ts tests/contact-intake.spec.ts",
    "test:news-contract": "vitest run tests/news-contract.test.mjs",
    "test:news": "vitest run tests/news-ui.test.ts tests/news-contract.test.mjs tests/news-metadata.test.mjs tests/news-rolling-feed.test.mjs tests/news-vercel-config.test.mjs",
    "test:news:e2e": "playwright test --config=playwright.news.config.ts",
    "validate:news-contract": "node scripts/validate-news-contract.mjs fixtures/news-contract/non-production/import-bundle.json",
    "verify:news-build": "node scripts/verify-news-build.mjs",
    "verify:news-build:review": "node scripts/verify-news-build.mjs dist/client review",
    "verify:news-build:production": "node scripts/verify-news-build.mjs dist/client production",
    "evidence:news-layout": "node scripts/generate-news-layout-evidence.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.7",
    "@fontsource/jetbrains-mono": "5.3.0",
    "@fontsource/noto-sans-jp": "5.3.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.3.7",
    "dompurify": "^3.4.5",
    "marked": "^18.0.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/qrcode": "^1.5.6",
    "svgo": "^4.0.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "path-to-regexp": "^6.3.0"
  }
