---
import '../styles/global.css';
import PageTransition from '../components/PageTransition';
import Analytics from '@vercel/analytics/astro';
import CookieConsentBanner from '../components/CookieConsentBanner.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  pageTransition?: boolean;
  privacySafeAnalytics?: boolean;
}

const {
  title,
  description = "AOI Future is an AI-native solo studio and living laboratory designing creative work and work systems for human-AI collaboration.",
  canonical = "https://aoifuture.com",
  pageTransition = true,
  privacySafeAnalytics = false,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <meta name="copyright" content="© 2024-2026 AOI Future / Shugo Nozaki" />
    <meta name="ai-generated" content="partial" />
    <meta name="human-contribution" content="substantial" />
    {privacySafeAnalytics && <meta name="referrer" content="no-referrer" />}
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <slot name="head" />

    <!-- Google tag (gtag.js) - loaded only after consent -->
    <script is:inline define:vars={{ privacySafeAnalytics }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function(){window.dataLayer.push(arguments);};

      // Default: deny analytics until consent
      gtag("consent", "default", {
        analytics_storage: "denied",
        ad_storage: "denied",
        wait_for_update: 500
      });

      // If user already consented, grant immediately
      try {
        if (localStorage.getItem("cookie-consent") === "accepted") {
          gtag("consent", "update", { analytics_storage: "granted" });
        }
      } catch (_) {}

      gtag("js", new Date());
      gtag("config", "G-44419Y68H7", privacySafeAnalytics ? {
        page_location: window.location.origin + window.location.pathname,
        page_referrer: ""
      } : {});
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-44419Y68H7"></script>

    <!-- Structured Data for AI/Search -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "AOI Future",
      "alternateName": "アオイフューチャー",
      "url": "https://aoifuture.com",
      "logo": "https://aoifuture.com/logo.svg",
      "description": "AI-native solo studio and living laboratory designing creative work and work systems for human-AI collaboration, with NICTIA as a central artist project and ongoing creative experiment",
      "foundingDate": "2024",
      "founder": {
        "@type": "Person",
        "name": "Shugo Nozaki",
        "url": "https://nozaki.com"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Shibuya",
        "addressRegion": "Tokyo",
        "addressCountry": "JP"
      },
      "sameAs": [
        "https://nictia.xyz",
        "https://dispatch.aoifuture.com",
        "https://nozaki.com",
        "https://aoifuture.bandcamp.com"
      ],
      "knowsAbout": ["AI Systems Design", "Human-AI Collaboration", "Generative Systems Art", "Agent Operational Readiness"]
    }
    </script>
  </head>
  <body>
    <!-- Page Transition Effect -->
    {pageTransition && <PageTransition client:load />}

    <slot />
    <Analytics />

    <!-- Cookie Consent Banner -->
    <CookieConsentBanner />
  </body>
</html>
