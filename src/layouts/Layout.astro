---
import '../styles/global.css';
import PageTransition from '../components/PageTransition';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  pageTransition?: boolean;
}

const {
  title,
  description = "AOI Future is an AI-native solo studio and living laboratory designing creative work and work systems for human-AI collaboration.",
  canonical = "https://aoifuture.com",
  pageTransition = true,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <meta name="copyright" content="© 2024-2026 AOI Future / Shugo Nozaki" />
    <meta name="ai-generated" content="partial" />
    <meta name="human-contribution" content="substantial" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <slot name="head" />

    <!-- Google tag (gtag.js) - loaded only after consent -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      // Default: deny analytics until consent
      gtag("consent", "default", {
        analytics_storage: "denied",
        ad_storage: "denied",
        wait_for_update: 500
      });

      // If user already consented, grant immediately
      if (localStorage.getItem("cookie-consent") === "accepted") {
        gtag("consent", "update", { analytics_storage: "granted" });
      }

      gtag("js", new Date());
      gtag("config", "G-44419Y68H7");
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-44419Y68H7"></script>

    <!-- Structured Data for AI/Search -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "AOI Future",
      "alternateName": "アオイフューチャー",
      "url": "https://aoifuture.com",
      "logo": "https://aoifuture.com/logo.svg",
      "description": "AI-native solo studio and living laboratory designing creative work and work systems for human-AI collaboration, with NICTIA as a central artist project and ongoing creative experiment",
      "foundingDate": "2024",
      "founder": {
        "@type": "Person",
        "name": "Shugo Nozaki",
        "url": "https://nozaki.com"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Shibuya",
        "addressRegion": "Tokyo",
        "addressCountry": "JP"
      },
      "sameAs": [
        "https://nictia.xyz",
        "https://dispatch.aoifuture.com",
        "https://nozaki.com",
        "https://aoifuture.bandcamp.com"
      ],
      "knowsAbout": ["AI Systems Design", "Human-AI Collaboration", "Generative Systems Art", "Agent Operational Readiness"]
    }
    </script>
  </head>
  <body>
    <!-- Page Transition Effect -->
    {pageTransition && <PageTransition client:load />}

    <slot />
    <Analytics />

    <!-- Cookie Consent Banner -->
    <div id="cookie-banner" style="display:none" class="fixed bottom-0 left-0 right-0 z-[100] bg-black/90 border-t border-cyan-400/30 px-4 py-3 backdrop-blur-sm">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-cyan-400/70 font-mono text-xs leading-relaxed">
          このサイトではGoogle Analyticsを使用しています。
          <a href="/privacy" class="text-cyan-400 hover:underline">プライバシーポリシー</a>
        </p>
        <div class="flex gap-2 shrink-0">
          <button id="cookie-reject" class="px-3 py-1.5 text-xs font-mono text-cyan-400/60 border border-cyan-400/30 hover:border-cyan-400/60 transition-colors cursor-pointer">
            拒否
          </button>
          <button id="cookie-accept" class="px-3 py-1.5 text-xs font-mono text-cyan-400 border border-cyan-400/50 bg-cyan-400/10 hover:bg-cyan-400/20 transition-colors cursor-pointer">
            同意
          </button>
        </div>
      </div>
    </div>
    <script is:inline>
      (function() {
        var consent = localStorage.getItem("cookie-consent");
        if (consent) return; // Already decided
        var banner = document.getElementById("cookie-banner");
        if (banner) banner.style.display = "block";
        document.getElementById("cookie-accept")?.addEventListener("click", function() {
          localStorage.setItem("cookie-consent", "accepted");
          gtag("consent", "update", { analytics_storage: "granted" });
          banner.style.display = "none";
        });
        document.getElementById("cookie-reject")?.addEventListener("click", function() {
          localStorage.setItem("cookie-consent", "rejected");
          banner.style.display = "none";
        });
      })();
    </script>
  </body>
</html>
