---
import type { NewsCatalog, NewsTopic } from '../../lib/news/types';

interface Props {
  catalog: NewsCatalog;
}

const { catalog } = Astro.props;
const topicById = new Map(catalog.editions.flatMap((edition) => (
  edition.topics.map((topic) => [topic.id, topic] as const)
)));
const topicRecords = new Map<string, {
  topic: NewsTopic;
  records: Array<{ edition: NewsCatalog['editions'][number]; signal: NewsCatalog['editions'][number]['items'][number] }>;
}>();
for (const edition of catalog.editions) {
  for (const signal of edition.items) {
    for (const topicId of signal.topics) {
      const topic = topicById.get(topicId);
      if (!topic) continue;
      const group = topicRecords.get(topicId) ?? { topic, records: [] };
      group.records.push({ edition, signal });
      topicRecords.set(topicId, group);
    }
  }
}
const topics = Array.from(topicRecords.values());
const sources = catalog.editions.flatMap((edition) => edition.items.map((signal) => ({ edition, signal })));
---

<div class="news-archive-grid">
  <section aria-labelledby="archive-editions">
    <h2 id="archive-editions">By Edition</h2>
    <ul>
      {catalog.editions.map((edition) => (
        <li><a href={`/news/${edition.edition_id}/`}><time datetime={edition.edition_date}>{edition.edition_date} JST</time> / {edition.title}</a></li>
      ))}
    </ul>
  </section>
  <section aria-labelledby="archive-contexts">
    <h2 id="archive-contexts">By Context</h2>
    <ul>
      {catalog.contexts.map((context) => (
        <li><a href={`/news/context/${context.slug}/`}>{context.title}</a></li>
      ))}
    </ul>
  </section>
  <section aria-labelledby="archive-topics">
    <h2 id="archive-topics">By topic</h2>
    <ul id="archive-topics-list">
      {topics.map(({ topic, records }) => (
        <li class="news-archive-topic" aria-labelledby={`topic-${topic.id}`}>
          <h3 id={`topic-${topic.id}`}>{topic.label_ja}</h3>
          {topic.description && <p>{topic.description}</p>}
          <ul>
            {records.map(({ edition, signal }) => (
              <li>
                <a href={`/news/${edition.edition_id}/#edition-${edition.edition_id}-${signal.id}`}>
                  <time datetime={edition.edition_date}>{edition.edition_date} JST</time> / {signal.title}
                </a>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </section>
  <section aria-labelledby="archive-sources">
    <h2 id="archive-sources">By source</h2>
    <ul id="archive-sources-list">
      {sources.map(({ edition, signal }) => (
        <li><a href={`/news/${edition.edition_id}/#edition-${edition.edition_id}-${signal.id}`}>{signal.source_domain} / {signal.source_title}</a></li>
      ))}
    </ul>
  </section>
</div>
