---
import '../styles/consulting.css';
import Analytics from '@vercel/analytics/astro';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AIと仕事する設計を、一緒に。実装伴走・月次ブリーフィング・スポット相談。野崎秀吾（Shugo Nozaki）のAI活用支援サービス。" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="robots" content="noai, noimageai" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <title>AIと仕事する設計を、一緒に | AOIFUTURE</title>

    <!-- Google tag (gtag.js) - loaded only after consent -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("consent", "default", {
        analytics_storage: "denied",
        ad_storage: "denied",
        wait_for_update: 500
      });
      if (localStorage.getItem("cookie-consent") === "accepted") {
        gtag("consent", "update", { analytics_storage: "granted" });
      }
      gtag("js", new Date());
      gtag("config", "G-44419Y68H7");
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-44419Y68H7"></script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Shugo Nozaki - AI運用設計",
      "provider": {
        "@type": "Person",
        "name": "Shugo Nozaki",
        "alternateName": "野崎秀吾"
      },
      "description": "AI実装伴走・月次AIブリーフィング・スポット相談。AIと仕事する設計を一緒に進めます。",
      "areaServed": "JP",
      "availableLanguage": ["ja", "en"]
    }
    </script>
  </head>

  <body class="bg-[var(--color-surface)] text-[var(--color-text)] font-[var(--font-sans)] leading-relaxed antialiased">

    <!-- ======================== HERO ======================== -->
    <section class="min-h-[90vh] flex flex-col justify-center px-6 md:px-12 lg:px-20 max-w-4xl mx-auto">
      <div class="mb-8">
        <span class="inline-block text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-6">
          Shugo Nozaki
        </span>
      </div>

      <h1 class="text-3xl md:text-[2.75rem] md:leading-[1.35] font-bold text-[var(--color-brand)] mb-8">
        AIと仕事する、<br />
        その設計から<br class="hidden md:inline" />一緒に。
      </h1>

      <p class="text-base md:text-lg text-[var(--color-text-muted)] max-w-2xl leading-loose mb-12">
        ChatGPTを入れた。Copilotも試した。社内研修もやった。<br />
        でも半年後、使っているのは最初から興味があった一人だけ。<br /><br />
        「ツールを入れる」ことはできた。<br />
        「AIが業務に溶け込む」ことは、まだできていない。<br /><br />
        問題はツールではなく、<span class="text-[var(--color-brand)] font-medium">誰がどこまで担うかという設計</span>にあります。<br />
        その設計と実装を、実際に手を動かしながら一緒に進めます。
      </p>

      <div class="space-y-4">
        <a
          href="https://aoifuture.notion.site/6a828f1f8371416187ab544742734fcd?pvs=105"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[var(--color-brand)] text-white
               px-8 py-4 text-sm font-medium tracking-wide
               hover:bg-[var(--color-brand-light)] transition-colors duration-300
               w-fit"
        >
          相談フォームへ
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <p class="text-sm text-[var(--color-text-light)] max-w-xl leading-relaxed">
          状況を簡単に書いて送ってください。1〜2営業日以内に返信します。
        </p>
      </div>
    </section>


    <!-- ======================== DIVIDER ======================== -->
    <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-20">
      <hr class="border-[var(--color-border)]" />
    </div>


    <!-- ======================== DIFFERENCE ======================== -->
    <section class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto py-24 md:py-32">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-brand)] mb-10">
        「使えるAI」と「動くAI」は違う
      </h2>

      <div class="space-y-6 text-[var(--color-text-muted)] leading-loose">
        <p>
          ChatGPTは使える。すごい。<br />
          でも、あれは「呼びかけたら答えてくれるAI」だ。
        </p>
        <p>
          ここで扱っているのは、<span class="text-[var(--color-text)] font-medium">呼びかけなくても動き続けるシステム</span>です。
        </p>
        <p>
          毎朝、起きる前にエージェント群が論文を読んでいる。<br />
          仕事に入る前に、別のエージェントがニュースをまとめている。<br />
          その日の失敗ログをもとに、次の動き方を更新する仕組みも回っている。
        </p>
        <p>
          これは単純な自動化ではなく、<span class="text-[var(--color-text)] font-medium">役割分担と観測を伴う運用</span>です。
        </p>
        <p>
          相談の場では、その運用実験で見えてきた知見を共有しながら、業務とエージェントの境界線を一緒に引いていきます。
        </p>
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="border-l-2 border-[var(--color-accent)] pl-6">
          <div class="text-3xl font-bold text-[var(--color-brand)] mb-2">15体</div>
          <div class="text-sm text-[var(--color-text-muted)]">並列稼働中のAIエージェント</div>
        </div>
        <div class="border-l-2 border-[var(--color-accent)] pl-6">
          <div class="text-3xl font-bold text-[var(--color-brand)] mb-2">25+</div>
          <div class="text-sm text-[var(--color-text-muted)]">VPS上のDockerコンテナ</div>
        </div>
        <div class="border-l-2 border-[var(--color-accent)] pl-6">
          <div class="text-3xl font-bold text-[var(--color-brand)] mb-2">20年+</div>
          <div class="text-sm text-[var(--color-text-muted)]">技術ブログの執筆経験</div>
        </div>
      </div>
    </section>


    <!-- ======================== DIVIDER ======================== -->
    <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-20">
      <hr class="border-[var(--color-border)]" />
    </div>


    <!-- ======================== ABOUT ======================== -->
    <section class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto py-24 md:py-32">
      <span class="text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-6 block">
        About
      </span>

      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-brand)] mb-10">
        背景にある実験
      </h2>

      <div class="space-y-6 text-[var(--color-text-muted)] leading-loose">
        <p>
          野崎秀吾（Shugo）。
        </p>
        <p>
          チームマネジメントとプロダクト設計を本業にしながら、個人ではAIエージェント群の運用実験を続けています。人間のチームとAIは別物です。ただ、両方を動かしてきたことで、仕事の設計に対する見方が変わりました。
        </p>
        <p>
          その延長で、こんな構造が見えてきました。
        </p>

        <blockquote class="border-l-2 border-[var(--color-accent-warm)] pl-6 py-2 my-8">
          <p class="text-[var(--color-text)] font-medium leading-loose">
            AIエージェントに指示を出すことと、<br />
            人間のチームに仕事を渡すことは、構造が同じだ。
          </p>
        </blockquote>

        <p>
          指示が曖昧だと、AIも人間も迷う。<br />
          完了の定義がないと、AIも人間も「やった」で終わる。<br />
          視点を渡さないと、AIも人間も「言われたこと」しかやらない。
        </p>
        <p>
          チームマネジメントの経験は、AIエージェント設計にそのまま接続されました。<br />
          逆に、エージェント運用の失敗と改善は、人間のチーム設計を見る解像度も上げてくれました。
        </p>
        <p class="text-[var(--color-text)] font-medium">
          ここでは、その往復運動から得た知見を共有します。
        </p>
      </div>
    </section>


    <!-- ======================== PROBLEMS ======================== -->
    <section class="bg-[var(--color-surface-alt)] py-24 md:py-32">
      <div class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto">
        <span class="text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-6 block">
          Use Cases
        </span>

      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-brand)] mb-12">
        こんな論点を扱います
      </h2>

        <div class="space-y-10">
          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              AIを導入したいが、何から始めればいいかわからない
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              業務の棚卸しから始めて、「これはAIに任せる」「これは人間が持つ」という境界線を一緒に引きます。
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              AIツールを入れてみたが、使われなくなった
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              定着しない理由を観察します。ツールの問題か、設計の問題か、運用の問題かを切り分けます。
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              繰り返しの作業を自動化したいが、外注すると高い
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              自社で持ちやすい最小構成を考えます。月数万円のAPI費用で回る設計か、別の手段がよいかも含めて検討します。
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              AIエージェントを作ったが、思い通りに動かない
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              プロンプト設計、記憶の設計、タスクの渡し方を見直しながら、どこにズレが生まれているかを確認します。
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              AIに何をどう任せるべきか、判断基準がない
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              「任せない方がいい仕事」と「任せた方がいい仕事」の判断軸を、現場の文脈に合わせて整理します。
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ======================== CASES ======================== -->
    <section class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto py-24 md:py-32">
      <span class="text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-6 block">
        Cases
      </span>

      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-brand)] mb-12">
        実績
      </h2>

      <div class="space-y-12">

        <!-- Case 1 -->
        <div class="border-l-2 border-[var(--color-accent)] pl-8 py-2">
          <div class="text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-3">Case 01 — スポット伴走</div>
          <h3 class="text-lg font-medium text-[var(--color-brand)] mb-4">
            残り1ヶ月の卒業制作を、1回で通した
          </h3>
          <div class="space-y-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
            <p>
              美術大学の学生から「提出まで1ヶ月を切ったが、制作にAIをどう使えばいいかわからない」という相談を受けた。
            </p>
            <p>
              無駄を省き、要点だけを押さえた1回のセッション。その後はオンラインで随時サポートしながら、提出まで伴走した。
            </p>
            <p class="text-[var(--color-text)] font-medium">
              「わかる」から「使える」へ。時間が限られているほど、設計の精度が成否を分ける。
            </p>
          </div>
        </div>

        <!-- Case 2 -->
        <div class="border-l-2 border-[var(--color-accent-warm)] pl-8 py-2">
          <div class="text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-3">Case 02 — 月次ブリーフィング</div>
          <h3 class="text-lg font-medium text-[var(--color-brand)] mb-4">
            「ChatGPTの使い方がわからない」から自律的にAIサービスを作るまで
          </h3>
          <div class="space-y-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
            <p>
              ある企業の執行役員（マーケティング担当）からの依頼。ChatGPTをどう使えばいいかわからない、という段階からスタート。
            </p>
            <p>
              毎月1回、業界トレンドを整理し、「この変化は自分の仕事にどう関係するか」を一緒に言語化するセッションを続けた。慣れ親しんだGoogle検索との違いを体感してもらいながら、粘り強く伴走した。
            </p>
            <p class="text-[var(--color-text)] font-medium">
              いまでは自律的にAIで業務ツールを作ってみる、いわゆる「バイブコーディング」にまで取り組んでいる。
            </p>
          </div>
        </div>

      </div>
    </section>


    <!-- ======================== DIVIDER ======================== -->
    <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-20">
      <hr class="border-[var(--color-border)]" />
    </div>


    <!-- ======================== SERVICES ======================== -->
    <section class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto py-24 md:py-32">
      <span class="text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-6 block">
        Services
      </span>

      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-brand)] mb-12">
        サービス内容
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Spot -->
        <div class="border border-[var(--color-border)] p-8 flex flex-col">
          <h3 class="text-sm font-medium text-[var(--color-text-light)] uppercase tracking-wider mb-4">
            Spot 相談
          </h3>
          <div class="text-2xl font-bold text-[var(--color-brand)] mb-1">
            ¥30,000
          </div>
          <div class="text-xs text-[var(--color-text-muted)] mb-6">1回 / 60分</div>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-8 flex-1">
            「いま迷っている論点を整理したい」<br />
            「方向性だけ先に確認したい」という方向け。
          </p>

          <ul class="text-sm text-[var(--color-text-muted)] space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              業務課題・AI活用の論点整理
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              AI/人間の役割分担設計
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              2週間アクションプランの提供
            </li>
          </ul>
        </div>

        <!-- AI実装伴走 -->
        <div class="border-2 border-[var(--color-brand)] p-8 flex flex-col relative">
          <div class="absolute -top-3 left-6 bg-[var(--color-brand)] text-white text-[10px] tracking-wider uppercase px-3 py-1">
            Recommended
          </div>

          <h3 class="text-sm font-medium text-[var(--color-text-light)] uppercase tracking-wider mb-4">
            AI実装伴走
          </h3>
          <div class="text-2xl font-bold text-[var(--color-brand)] mb-1">
            ¥80,000〜120,000
          </div>
          <div class="text-xs text-[var(--color-text-muted)] mb-6">月額 / セッション月2〜4回</div>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-8 flex-1">
            「実際に作りながら学びたい」<br />
            「自分でも動かせる仕組みを手元に残したい」という方向け。
          </p>

          <ul class="text-sm text-[var(--color-text-muted)] space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              月2〜4回のセッション（各60分）
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              実装サポート・プロンプト設計
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              Discordでの非同期相談
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              設計レビュー・導入判断
            </li>
          </ul>
        </div>

        <!-- 月次ブリーフィング 個人 -->
        <div class="border border-[var(--color-border)] p-8 flex flex-col">
          <h3 class="text-sm font-medium text-[var(--color-text-light)] uppercase tracking-wider mb-4">
            月次AIブリーフィング（個人）
          </h3>
          <div class="text-2xl font-bold text-[var(--color-brand)] mb-1">
            ¥60,000
          </div>
          <div class="text-xs text-[var(--color-text-muted)] mb-6">月額 / 月1回60分</div>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-8 flex-1">
            「AI動向を自分の業務文脈で把握したい」<br />
            「判断の精度を上げる情報を継続的に欲しい」という方向け。
          </p>

          <ul class="text-sm text-[var(--color-text-muted)] space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              月1回の個別ブリーフィング（60分）
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              業界トレンドの解説と業務への適用方法
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              Q&A・論点の言語化サポート
            </li>
          </ul>
        </div>

        <!-- 月次ブリーフィング チーム -->
        <div class="border border-[var(--color-border)] p-8 flex flex-col">
          <h3 class="text-sm font-medium text-[var(--color-text-light)] uppercase tracking-wider mb-4">
            月次AIブリーフィング（チーム）
          </h3>
          <div class="text-2xl font-bold text-[var(--color-brand)] mb-1">
            ¥150,000
          </div>
          <div class="text-xs text-[var(--color-text-muted)] mb-6">月額 / 3〜10名対象</div>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-8 flex-1">
            「チーム全員のAIリテラシーを底上げしたい」<br />
            「経営層とメンバーの認識を揃えたい」という方向け。
          </p>

          <ul class="text-sm text-[var(--color-text-muted)] space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              月1回のチームブリーフィング（60〜90分）
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              チームに合わせたカスタム資料
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              チームQ&Aセッション
            </li>
          </ul>
        </div>

      </div>
    </section>


    <!-- ======================== DIVIDER ======================== -->
    <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-20">
      <hr class="border-[var(--color-border)]" />
    </div>


    <!-- ======================== FIT / NOT FIT ======================== -->
    <section class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto py-24 md:py-32">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
        <div>
          <h3 class="text-lg font-bold text-[var(--color-brand)] mb-6">向いている方</h3>
          <ul class="space-y-4 text-sm text-[var(--color-text-muted)] leading-relaxed">
