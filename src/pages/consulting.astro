    <script is:inline>
      const form = document.querySelector('#consulting-chat-form');

      if (form instanceof HTMLFormElement) {
        const textarea = form.querySelector('#consulting-chat-message');
        const submitButton = form.querySelector('#consulting-chat-submit');
        const submitLabel = form.querySelector('[data-submit-label]');
        const status = form.querySelector('#consulting-chat-status');

        const setStatus = (message, tone = 'default') => {
          if (!(status instanceof HTMLElement)) return;
          status.textContent = message;
          status.classList.remove('text-white/70', 'text-emerald-200', 'text-red-200');

          if (tone === 'success') {
            status.classList.add('text-emerald-200');
            return;
          }

          if (tone === 'error') {
            status.classList.add('text-red-200');
            return;
          }

          status.classList.add('text-white/70');
        };

        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          if (!(textarea instanceof HTMLTextAreaElement) || !(submitButton instanceof HTMLButtonElement) || !(submitLabel instanceof HTMLElement)) {
            return;
          }

          const message = textarea.value.trim();

          if (!message) {
            setStatus('相談内容を入力してください。', 'error');
            textarea.focus();
            return;
          }

          submitButton.disabled = true;
          submitLabel.textContent = '送信中...';
          setStatus('送信しています...');

          try {
            const response = await fetch('/api/v1/messages', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                to: 'channel:1479016713445048391',
                message,
              }),
            });

            if (!response.ok) {
              throw new Error(`Request failed: ${response.status}`);
            }

            textarea.value = '';
            setStatus('送信しました。内容を確認し、折り返し連絡します。', 'success');
          } catch (error) {
            console.error(error);
            setStatus('送信に失敗しました。時間をおいて再度お試しください。', 'error');
          } finally {
            submitButton.disabled = false;
            submitLabel.textContent = '送信する';
          }
        });
      }
    </script>

