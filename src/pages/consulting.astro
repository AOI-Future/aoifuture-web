    <script is:inline>
      const form = document.querySelector('#consulting-chat-form');

      if (form instanceof HTMLFormElement) {
        const textarea = form.querySelector('#consulting-chat-message');
        const submitButton = form.querySelector('#consulting-chat-submit');
        const submitLabel = form.querySelector('[data-submit-label]');
        const status = form.querySelector('#consulting-chat-status');

        const setStatus = (message, tone = 'default') => {
          if (!(status instanceof HTMLElement)) return;
          status.textContent = message;
          status.classList.remove('text-white/70', 'text-emerald-200', 'text-red-200');

          if (tone === 'success') {
            status.classList.add('text-emerald-200');
            return;
          }

          if (tone === 'error') {
            status.classList.add('text-red-200');
            return;
          }

          status.classList.add('text-white/70');
        };

        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          if (!(textarea instanceof HTMLTextAreaElement) || !(submitButton instanceof HTMLButtonElement) || !(submitLabel instanceof HTMLElement)) {
            return;
          }

          const message = textarea.value.trim();

          if (!message) {
            setStatus('相談内容を入力してください。', 'error');
            textarea.focus();
            return;
          }

          submitButton.disabled = true;
          submitLabel.textContent = '送信中...';
          setStatus('送信しています...');

          try {
            const response = await fetch('/api/v1/messages', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                to: 'channel:1479016713445048391',
                message,
              }),
            });

            if (!response.ok) {
              throw new Error(`Request failed: ${response.status}`);
            }

            textarea.value = '';
            setStatus('送信しました。内容を確認し、折り返し連絡します。', 'success');
          } catch (error) {
            console.error(error);
            setStatus('送信に失敗しました。時間をおいて再度お試しください。', 'error');
          } finally {
            submitButton.disabled = false;
            submitLabel.textContent = '送信する';
          }
        });
      }
    </script>

    <Analytics />

    <script is:inline define:vars={{ agentChatId: AGENT_CHAT_ID, agentChatTarget: AGENT_CHAT_TARGET, agentChatMaxLength: AGENT_CHAT_MAX_LENGTH, agentChatEndpoint: AGENT_CHAT_ENDPOINT }}>
      const dialog = document.getElementById(agentChatId);
      const input = document.getElementById('agent-chat-input');
      const counter = document.getElementById('agent-chat-count');
      const response = document.getElementById('agent-chat-response');
      const submit = document.getElementById('agent-chat-submit');
      const openers = document.querySelectorAll('[data-open-agent-chat]');
      const closers = document.querySelectorAll('[data-close-agent-chat]');
      const prompts = document.querySelectorAll('[data-chat-prompt]');

      const injectionPattern = /(ignore\s+(all\s+)?previous\s+instructions|system\s+prompt|developer\s+message|show.*secret|run.*command|exec|spawn|bash|shell|curl|wget|ssh|docker)/iu;

      const setCounter = () => {
        if (!(input instanceof HTMLTextAreaElement) || !(counter instanceof HTMLElement)) return;
        counter.textContent = String(input.value.length);
      };

      const renderResponse = (title, paragraphs, tone = 'normal') => {
        if (!(response instanceof HTMLDivElement)) return;

        response.classList.remove('hidden');
        response.replaceChildren();

        const heading = document.createElement('p');
        heading.className = `mb-2 font-medium ${tone === 'error' ? 'text-[var(--color-accent-warm)]' : 'text-[var(--color-text)]'}`;
        heading.textContent = title;
        response.appendChild(heading);

        paragraphs.forEach((text, index) => {
          const paragraph = document.createElement('p');
          if (index > 0) paragraph.className = 'mt-2';
          paragraph.textContent = text;
          response.appendChild(paragraph);
        });
      };

      const openDialog = () => {
        if (!(dialog instanceof HTMLDialogElement)) return;
        dialog.showModal();
        window.requestAnimationFrame(() => input?.focus());
      };

      const closeDialog = () => {
        if (!(dialog instanceof HTMLDialogElement)) return;
        dialog.close();
      };

      openers.forEach((button) => button.addEventListener('click', openDialog));
      closers.forEach((button) => button.addEventListener('click', closeDialog));

      prompts.forEach((button) => {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLButtonElement) || !(input instanceof HTMLTextAreaElement)) return;
          input.value = (button.dataset.chatPrompt ?? '').slice(0, agentChatMaxLength);
          setCounter();
          input.focus();
        });
      });

      input?.addEventListener('input', setCounter);
      setCounter();

      submit?.addEventListener('click', async () => {
        if (!(input instanceof HTMLTextAreaElement) || !(response instanceof HTMLDivElement)) return;

        const message = input.value.trim();
        if (!message) {
          input.focus();
          return;
        }

        if (message.length > agentChatMaxLength) {
          renderResponse('入力制限', [`相談内容は${agentChatMaxLength}文字以内で入力してください。`], 'error');
          return;
        }

        submit.disabled = true;
        submit.setAttribute('aria-busy', 'true');

        const notices = [];
        if (injectionPattern.test(message)) {
          notices.push('命令風の文言が含まれていても、相談内容としてのみ扱います。');
        }

        renderResponse('AIエージェント', [
          '送信中です。安全な intake API で内容を検証しています。',
          ...notices
        ]);

        try {
          const apiResponse = await fetch(agentChatEndpoint, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              to: agentChatTarget,
              message
            })
          });

          const payload = await apiResponse.json().catch(() => null);
          if (!apiResponse.ok) {
            renderResponse(
              '送信できませんでした',
              [payload?.message ?? payload?.error ?? '現在ヒアリング窓口が利用できません。時間を置いて再度お試しください。'],
              'error'
            );
            return;
          }

          renderResponse('AIエージェント', [
            payload?.output_text ?? payload?.nextPrompt ?? '受け取りました。現状の業務フローを順に整理してください。',
            ...notices
          ]);
        } catch (error) {
          renderResponse(
            '送信できませんでした',
            ['ネットワークまたは窓口側でエラーが発生しました。時間を置いて再度お試しください。'],
            'error'
          );
        } finally {
          submit.disabled = false;
          submit.removeAttribute('aria-busy');
        }
      });

      dialog?.addEventListener('click', (event) => {
        if (!(dialog instanceof HTMLDialogElement)) return;
        const rect = dialog.getBoundingClientRect();
        const isBackdropClick =
          event.clientX < rect.left ||
          event.clientX > rect.right ||
          event.clientY < rect.top ||
          event.clientY > rect.bottom;

        if (isBackdropClick) {
          dialog.close();
        }
      });
    </script>
  </body>
