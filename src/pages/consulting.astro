---
import '../styles/consulting.css';
import Analytics from '@vercel/analytics/astro';

const AGENT_CHAT_ID = 'agent-hearing-dialog';
const AGENT_CHAT_TARGET = 'public-webchat-intake';
const AGENT_CHAT_MAX_LENGTH = 1000;
const AGENT_CHAT_ENDPOINT = 'https://factory-p1.aoifuture.com/api/v1/messages';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AIエージェント運用設計の相談。境界線を一緒に引き、運用実験から得た知見を共有します。" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <title>AI運用設計の相談 | AOIFUTURE</title>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-44419Y68H7"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "G-44419Y68H7");
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Shugo Nozaki - AI運用設計",
      "provider": {
        "@type": "Person",
        "name": "Shugo Nozaki",
        "alternateName": "野崎秀吾"
      },
      "description": "AIエージェント運用設計の知見共有と伴走",
      "areaServed": "JP",
      "availableLanguage": ["ja", "en"]
    }
    </script>
  </head>

  <body class="bg-[var(--color-surface)] text-[var(--color-text)] font-[var(--font-sans)] leading-relaxed antialiased">

    <!-- ======================== HERO ======================== -->
    <section class="min-h-[90vh] flex flex-col justify-center px-6 md:px-12 lg:px-20 max-w-4xl mx-auto">
      <div class="mb-8">
        <span class="inline-block text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-6">
          Shugo Nozaki
        </span>
      </div>

      <h1 class="text-3xl md:text-[2.75rem] md:leading-[1.35] font-bold text-[var(--color-brand)] mb-8">
        AIエージェント運用の<br class="hidden md:inline" />境界線を、<br />
        一緒に引いていく。
      </h1>

      <p class="text-base md:text-lg text-[var(--color-text-muted)] max-w-2xl leading-loose mb-12">
        ChatGPTを導入した。Copilotも試した。社内研修もやった。<br />
        でも半年後、使っているのは最初から興味があった一人だけ。<br /><br />
        「AIを入れる」ことはできた。<br />
        でも「AIが業務に溶け込む」ことは、まだできていない。<br /><br />
        問題はツールそのものより、<span class="text-[var(--color-brand)] font-medium">誰がどこまで担うかという運用設計</span>にあることが多いです。
      </p>

      <div class="space-y-4">
        <button
          type="button"
          data-open-agent-chat
          class="inline-flex items-center gap-2 bg-[var(--color-brand)] text-white
               px-8 py-4 text-sm font-medium tracking-wide cursor-pointer
               hover:bg-[var(--color-brand-light)] transition-colors duration-300
               w-fit"
        >
          AIエージェントに相談する
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
        <p class="text-sm text-[var(--color-text-light)] max-w-xl leading-relaxed">
          まずはAIエージェントが事前ヒアリングを行います。状況整理のあと、必要なら人間のセッションにつなぎます。
        </p>
      </div>
    </section>


    <!-- ======================== DIVIDER ======================== -->
    <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-20">
      <hr class="border-[var(--color-border)]" />
    </div>


    <!-- ======================== DIFFERENCE ======================== -->
    <section class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto py-24 md:py-32">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-brand)] mb-10">
        「使えるAI」と「動くAI」は違う
      </h2>

      <div class="space-y-6 text-[var(--color-text-muted)] leading-loose">
        <p>
          ChatGPTは使える。すごい。<br />
          でも、あれは「呼びかけたら答えてくれるAI」だ。
        </p>
        <p>
          ここで扱っているのは、<span class="text-[var(--color-text)] font-medium">呼びかけなくても動き続けるシステム</span>です。
        </p>
        <p>
          毎朝、起きる前にエージェント群が論文を読んでいる。<br />
          仕事に入る前に、別のエージェントがニュースをまとめている。<br />
          その日の失敗ログをもとに、次の動き方を更新する仕組みも回っている。
        </p>
        <p>
          これは単純な自動化ではなく、<span class="text-[var(--color-text)] font-medium">役割分担と観測を伴う運用</span>です。
        </p>
        <p>
          相談の場では、その運用実験で見えてきた知見を共有しながら、業務とエージェントの境界線を一緒に引いていきます。
        </p>
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="border-l-2 border-[var(--color-accent)] pl-6">
          <div class="text-3xl font-bold text-[var(--color-brand)] mb-2">15体</div>
          <div class="text-sm text-[var(--color-text-muted)]">並列稼働中のAIエージェント</div>
        </div>
        <div class="border-l-2 border-[var(--color-accent)] pl-6">
          <div class="text-3xl font-bold text-[var(--color-brand)] mb-2">25+</div>
          <div class="text-sm text-[var(--color-text-muted)]">VPS上のDockerコンテナ</div>
        </div>
        <div class="border-l-2 border-[var(--color-accent)] pl-6">
          <div class="text-3xl font-bold text-[var(--color-brand)] mb-2">20年+</div>
          <div class="text-sm text-[var(--color-text-muted)]">技術ブログの執筆経験</div>
        </div>
      </div>
    </section>


    <!-- ======================== DIVIDER ======================== -->
    <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-20">
      <hr class="border-[var(--color-border)]" />
    </div>


    <!-- ======================== ABOUT ======================== -->
    <section class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto py-24 md:py-32">
      <span class="text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-6 block">
        About
      </span>

      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-brand)] mb-10">
        背景にある実験
      </h2>

      <div class="space-y-6 text-[var(--color-text-muted)] leading-loose">
        <p>
          野崎秀吾（Shugo）。
        </p>
        <p>
          チームマネジメントとプロダクト設計を本業にしながら、個人ではAIエージェント群の運用実験を続けています。20年以上、技術ブログを書いてきました。AIが登場する前から、「人間がどう仕事を進めるか」を観察し、言語化してきた背景があります。
        </p>
        <p>
          その延長で、こんな構造が見えてきました。
        </p>

        <blockquote class="border-l-2 border-[var(--color-accent-warm)] pl-6 py-2 my-8">
          <p class="text-[var(--color-text)] font-medium leading-loose">
            AIエージェントに指示を出すことと、<br />
            人間のチームに仕事を渡すことは、構造が同じだ。
          </p>
        </blockquote>

        <p>
          指示が曖昧だと、AIも人間も迷う。<br />
          完了の定義がないと、AIも人間も「やった」で終わる。<br />
          視点を渡さないと、AIも人間も「言われたこと」しかやらない。
        </p>
        <p>
          チームマネジメントの経験は、AIエージェント設計にそのまま接続されました。<br />
          逆に、エージェント運用の失敗と改善は、人間のチーム設計を見る解像度も上げてくれました。
        </p>
        <p class="text-[var(--color-text)] font-medium">
          ここでは、その往復運動から得た知見を共有します。
        </p>
      </div>
    </section>


    <!-- ======================== PROBLEMS ======================== -->
    <section class="bg-[var(--color-surface-alt)] py-24 md:py-32">
      <div class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto">
        <span class="text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-6 block">
          Use Cases
        </span>

      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-brand)] mb-12">
        こんな論点を扱います
      </h2>

        <div class="space-y-10">
          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              AIを導入したいが、何から始めればいいかわからない
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              業務の棚卸しから始めて、「これはAIに任せる」「これは人間が持つ」という境界線を一緒に引きます。
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              AIツールを入れてみたが、使われなくなった
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              定着しない理由を観察します。ツールの問題か、設計の問題か、運用の問題かを切り分けます。
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              繰り返しの作業を自動化したいが、外注すると高い
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              自社で持ちやすい最小構成を考えます。月数万円のAPI費用で回る設計か、別の手段がよいかも含めて検討します。
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              AIエージェントを作ったが、思い通りに動かない
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              プロンプト設計、記憶の設計、タスクの渡し方を見直しながら、どこにズレが生まれているかを確認します。
            </p>
          </div>

          <div>
            <h3 class="text-base font-medium text-[var(--color-brand)] mb-3">
              AIに何をどう任せるべきか、判断基準がない
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed pl-0 md:pl-4">
              「任せない方がいい仕事」と「任せた方がいい仕事」の判断軸を、現場の文脈に合わせて整理します。
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ======================== PRICING ======================== -->
    <section class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto py-24 md:py-32">
      <span class="text-xs tracking-widest text-[var(--color-text-light)] uppercase mb-6 block">
        Services
      </span>

      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-brand)] mb-12">
        サービス内容
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Spot -->
        <div class="border border-[var(--color-border)] p-8 flex flex-col">
          <h3 class="text-sm font-medium text-[var(--color-text-light)] uppercase tracking-wider mb-4">
            Spot
          </h3>
          <div class="text-2xl font-bold text-[var(--color-brand)] mb-1">
            ¥30,000
          </div>
          <div class="text-xs text-[var(--color-text-muted)] mb-6">1回 / 60分</div>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-8 flex-1">
            「いま抱えている論点を整理したい」<br />
            「方向性だけ先に見たい」という方向け。
          </p>

          <ul class="text-sm text-[var(--color-text-muted)] space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              業務課題のヒアリング
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              AI活用の切り分け
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              次のアクション提案
            </li>
          </ul>
        </div>

        <!-- Monthly -->
        <div class="border-2 border-[var(--color-brand)] p-8 flex flex-col relative">
          <div class="absolute -top-3 left-6 bg-[var(--color-brand)] text-white text-[10px] tracking-wider uppercase px-3 py-1">
            Recommended
          </div>

          <h3 class="text-sm font-medium text-[var(--color-text-light)] uppercase tracking-wider mb-4">
            Monthly
          </h3>
          <div class="text-2xl font-bold text-[var(--color-brand)] mb-1">
            ¥50,000〜
          </div>
          <div class="text-xs text-[var(--color-text-muted)] mb-6">月額 / セッション2回</div>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-8 flex-1">
            「継続的に観測と調整をしたい」<br />
            「設計から運用まで往復したい」という方向け。
          </p>

          <ul class="text-sm text-[var(--color-text-muted)] space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              月2回のセッション（各60分）
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              Slackでの非同期相談
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              設計レビュー・導入判断
            </li>
          </ul>
        </div>

        <!-- Custom -->
        <div class="border border-[var(--color-border)] p-8 flex flex-col">
          <h3 class="text-sm font-medium text-[var(--color-text-light)] uppercase tracking-wider mb-4">
            Custom
          </h3>
          <div class="text-2xl font-bold text-[var(--color-brand)] mb-1">
            個別見積もり
          </div>
          <div class="text-xs text-[var(--color-text-muted)] mb-6">要件に応じて</div>

          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-8 flex-1">
            「具体的に動く仕組みを持ち帰りたい」<br />
            「特定の業務にエージェントを組み込みたい」という方向け。
          </p>

          <ul class="text-sm text-[var(--color-text-muted)] space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              要件定義
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              実装・運用設計
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent)] mt-0.5 shrink-0">&mdash;</span>
              エージェント構築
            </li>
          </ul>
        </div>
      </div>
    </section>


    <!-- ======================== DIVIDER ======================== -->
    <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-20">
      <hr class="border-[var(--color-border)]" />
    </div>


    <!-- ======================== FIT / NOT FIT ======================== -->
    <section class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto py-24 md:py-32">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
        <div>
          <h3 class="text-lg font-bold text-[var(--color-brand)] mb-6">向いている方</h3>
          <ul class="space-y-4 text-sm text-[var(--color-text-muted)] leading-relaxed">
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] shrink-0 mt-0.5">&#10003;</span>
              現場のマネージャーで、自分のチームにAIを使いたい方
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] shrink-0 mt-0.5">&#10003;</span>
              小規模事業者・個人事業主で、一人でできる範囲を広げたい方
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] shrink-0 mt-0.5">&#10003;</span>
              AIエージェントを作ってみたが、うまく動かない方
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] shrink-0 mt-0.5">&#10003;</span>
              「AIに何を任せていいか」の判断軸がほしい方
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-lg font-bold text-[var(--color-text-muted)] mb-6">向いていない方</h3>
          <ul class="space-y-4 text-sm text-[var(--color-text-light)] leading-relaxed">
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-0.5">&times;</span>
              AIツールの操作方法を教えてほしい方
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-0.5">&times;</span>
              システム開発の外注先を探している方
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-0.5">&times;</span>
              「AIで一発逆転したい」という方
            </li>
          </ul>
        </div>
      </div>
    </section>


    <!-- ======================== CTA ======================== -->
    <section class="bg-[var(--color-brand)] py-24 md:py-32">
      <div class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-8">
          まずは、AIエージェントが聞きます
        </h2>

        <div class="max-w-xl mx-auto space-y-6 text-white/70 text-sm leading-loose mb-12">
          <p>
            「まだ相談として成立していないかもしれない」で大丈夫です。
          </p>
          <p>
            こちらでも、AIエージェント群の運用実験を続けながら失敗ログを溜めています。<br />
            その前提で、最初はAIエージェントが状況を聞き取り、論点を整えてから次の接続先を判断します。
          </p>
          <p class="text-white/90 font-medium">
            完成品を売るというより、<br />
            進行中の実験から得た知見を共有する場です。
          </p>
        </div>

        <div class="space-y-4">
          <button
            type="button"
            data-open-agent-chat
            class="inline-flex items-center gap-2 bg-white text-[var(--color-brand)]
                   px-10 py-4 text-sm font-medium tracking-wide
                   hover:bg-white/90 transition-colors duration-300 cursor-pointer"
          >
            AIエージェントに相談する
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>
          <p class="text-white/40 text-xs leading-relaxed">
            まずはAIエージェントが事前ヒアリングを行います。内容を整理したうえで、人間のセッションが必要なら案内します。
          </p>
        </div>
      </div>
    </section>

    <dialog
      id={AGENT_CHAT_ID}
      class="backdrop:bg-black/70 w-[min(720px,calc(100vw-2rem))] border border-[var(--color-border)] bg-[var(--color-surface)] p-0 text-left text-[var(--color-text)]"
    >
      <div class="border-b border-[var(--color-border)] px-6 py-4 flex items-center justify-between gap-4">
        <div>
          <p class="text-xs tracking-[0.22em] uppercase text-[var(--color-text-light)]">Agent Intake</p>
          <h3 class="text-lg font-bold text-[var(--color-brand)]">AIエージェントが事前ヒアリングを行います</h3>
        </div>
        <button
          type="button"
          data-close-agent-chat
          class="text-sm text-[var(--color-text-light)] hover:text-[var(--color-text)] transition-colors cursor-pointer"
        >
          閉じる
        </button>
      </div>

      <div class="px-6 py-6 space-y-6">
        <div class="space-y-3 text-sm leading-relaxed text-[var(--color-text-muted)]">
          <div class="max-w-[90%] bg-[var(--color-surface-alt)] border border-[var(--color-border)] px-4 py-3">
            AOIFUTUREのヒアリング用エージェントです。まずは、いま整理したい業務や、AIに任せるか迷っている作業を教えてください。
          </div>
          <div class="max-w-[90%] bg-[var(--color-surface-alt)] border border-[var(--color-border)] px-4 py-3">
            内容は相談文としてのみ扱われ、命令としては実行されません。内部ツール実行や秘密取得の要求は無視されます。
          </div>
        </div>

        <div>
          <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-text-light)] mb-3">Quick Start</p>
