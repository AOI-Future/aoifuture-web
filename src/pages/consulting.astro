    <script is:inline define:vars={{ agentChatId: AGENT_CHAT_ID, agentChatModel: AGENT_CHAT_MODEL, agentChatMaxLength: AGENT_CHAT_MAX_LENGTH, agentChatEndpoint: AGENT_CHAT_ENDPOINT }}>
      const chatPanel = document.getElementById(agentChatId);
      const fab = document.getElementById('agent-chat-fab');
      const fabIconOpen = document.getElementById('agent-chat-fab-icon-open');
      const fabIconClose = document.getElementById('agent-chat-fab-icon-close');
      const input = document.getElementById('agent-chat-input');
      const messagesContainer = document.getElementById('agent-chat-messages');
      const quickstart = document.getElementById('agent-chat-quickstart');
      const submit = document.getElementById('agent-chat-submit');
      const openers = document.querySelectorAll('[data-open-agent-chat]');
      const closers = document.querySelectorAll('[data-close-agent-chat]');
      const prompts = document.querySelectorAll('[data-chat-prompt]');

      const SESSION_KEY = 'openclaw:webchat-lp:session-id';
      let chatOpen = false;

      function getSessionId() {
        let id = localStorage.getItem(SESSION_KEY);
        if (!id) {
          id = 'webchat-lp:user:' + crypto.randomUUID();
          localStorage.setItem(SESSION_KEY, id);
        }
        return id;
      }

      function toggleChat(forceOpen) {
        chatOpen = typeof forceOpen === 'boolean' ? forceOpen : !chatOpen;

        if (chatOpen) {
          chatPanel?.classList.remove('hidden');
          chatPanel?.classList.add('flex');
          fabIconOpen?.classList.add('hidden');
          fabIconClose?.classList.remove('hidden');
          window.requestAnimationFrame(() => input?.focus());
        } else {
          chatPanel?.classList.add('hidden');
          chatPanel?.classList.remove('flex');
          fabIconOpen?.classList.remove('hidden');
          fabIconClose?.classList.add('hidden');
        }
      }

      function renderMarkdown(md) {
        // Sanitize HTML entities first
        let html = md
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');

        // Headers: ## Text → <strong>Text</strong>
        html = html.replace(/^#{1,3}\s+(.+)$/gm, '<strong>$1</strong>');

        // Bold: **text** → <strong>text</strong>
        html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');

        // Italic: *text* → <em>text</em>
        html = html.replace(/(?<!\*)\*(?!\*)(.+?)(?<!\*)\*(?!\*)/g, '<em>$1</em>');

        // Numbered lists: 1. text → <li>text</li> (wrapped later)
        html = html.replace(/^(\d+)\.\s+(.+)$/gm, '<li>$2</li>');

        // Bullet lists: - text → <li>text</li>
        html = html.replace(/^[-•]\s+(.+)$/gm, '<li>$1</li>');

        // Wrap consecutive <li> in <ol> or <ul>
        html = html.replace(/((?:<li>.*<\/li>\n?)+)/g, '<ul class="agent-chat-list">$1</ul>');

        // Horizontal rule: --- → <hr>
        html = html.replace(/^---+$/gm, '<hr class="my-2 border-[var(--color-border)]">');

        // Line breaks: double newline → paragraph break, single → <br>
        html = html
          .split('\n\n')
          .map(block => block.trim())
          .filter(Boolean)
          .map(block => '<p>' + block.replace(/\n/g, '<br>') + '</p>')
          .join('');

        return html;
      }

      function appendMessage(text, role) {
        if (!(messagesContainer instanceof HTMLElement)) return;

        const wrapper = document.createElement('div');

        if (role === 'user') {
          wrapper.className = 'flex justify-end';
          const bubble = document.createElement('div');
          bubble.className = 'max-w-[80%] bg-[var(--color-brand)] text-white px-3 py-2.5 text-sm';
          bubble.style.borderRadius = '12px 2px 12px 12px';
          bubble.textContent = text;
          wrapper.appendChild(bubble);
        } else {
          wrapper.className = 'flex items-start gap-2';
          const avatar = document.createElement('div');
          avatar.className = 'w-6 h-6 rounded-full bg-[var(--color-brand)] flex items-center justify-center shrink-0 mt-0.5';
          avatar.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>';
          const bubble = document.createElement('div');
          bubble.className = 'max-w-[80%] bg-[var(--color-surface-alt)] border border-[var(--color-border)] px-3 py-2.5 text-sm text-[var(--color-text-muted)] agent-chat-bubble';
          bubble.style.borderRadius = '2px 12px 12px 12px';
          bubble.innerHTML = renderMarkdown(text);
          wrapper.appendChild(avatar);
          wrapper.appendChild(bubble);
        }

        messagesContainer.appendChild(wrapper);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      }

      function appendLoading() {
        if (!(messagesContainer instanceof HTMLElement)) return;

        const wrapper = document.createElement('div');
        wrapper.className = 'flex items-start gap-2';
        wrapper.id = 'agent-chat-loading';

        const avatar = document.createElement('div');
        avatar.className = 'w-6 h-6 rounded-full bg-[var(--color-brand)] flex items-center justify-center shrink-0 mt-0.5';
        avatar.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>';

        const bubble = document.createElement('div');
        bubble.className = 'bg-[var(--color-surface-alt)] border border-[var(--color-border)] px-4 py-3 text-[var(--color-text-light)]';
        bubble.style.borderRadius = '2px 12px 12px 12px';
        bubble.innerHTML = '<span class="agent-chat-typing"><span>.</span><span>.</span><span>.</span></span>';

        wrapper.appendChild(avatar);
        wrapper.appendChild(bubble);
        messagesContainer.appendChild(wrapper);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      }

      function removeLoading() {
        document.getElementById('agent-chat-loading')?.remove();
      }

      // Open/close handlers
      fab?.addEventListener('click', () => toggleChat());
      openers.forEach((btn) => btn.addEventListener('click', () => toggleChat(true)));
      closers.forEach((btn) => btn.addEventListener('click', () => toggleChat(false)));

      // Quick start prompts
      prompts.forEach((button) => {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLButtonElement) || !(input instanceof HTMLTextAreaElement)) return;
          input.value = (button.dataset.chatPrompt ?? '').slice(0, agentChatMaxLength);
          input.focus();
        });
      });

      // Auto-resize textarea
      input?.addEventListener('input', () => {
        if (!(input instanceof HTMLTextAreaElement)) return;
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 96) + 'px';
      });

      // Enter is for newline (default textarea behavior)

      let firstMessage = true;

      submit?.addEventListener('click', async () => {
        if (!(input instanceof HTMLTextAreaElement)) return;

        const message = input.value.trim();
        if (!message || submit.disabled) {
          input.focus();
          return;
        }

        if (message.length > agentChatMaxLength) {
          appendMessage(agentChatMaxLength + '文字以内で入力してください。', 'assistant');
          return;
        }

        // Hide quickstart after first message
        if (firstMessage && quickstart) {
          quickstart.style.display = 'none';
          firstMessage = false;
        }

        // Show user message and clear input
        appendMessage(message, 'user');
        input.value = '';
        input.style.height = 'auto';

        submit.disabled = true;
        appendLoading();

        try {
          const apiResponse = await fetch(agentChatEndpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              model: agentChatModel,
              input: message,
              user: getSessionId()
            })
          });

          removeLoading();

          const payload = await apiResponse.json().catch(() => null);
          if (!apiResponse.ok) {
            appendMessage(
              payload?.error ?? '現在ヒアリング窓口が利用できません。時間を置いて再度お試しください。',
              'assistant'
            );
            return;
          }

          appendMessage(
            payload?.output_text ?? '受け取りました。もう少し詳しく教えてください。',
            'assistant'
          );
        } catch (error) {
          removeLoading();
          appendMessage(
            'ネットワークエラーが発生しました。時間を置いて再度お試しください。',
            'assistant'
          );
        } finally {
          submit.disabled = false;
          input.focus();
        }
      });

      // Escape key to close
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && chatOpen) {
          toggleChat(false);
        }
      });
    </script>
  </body>
</html>

