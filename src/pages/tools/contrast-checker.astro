---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="CONTRAST CHECKER | AOI Tools">
  <main class="relative min-h-screen bg-black text-cyan-400 font-mono">
    <a href="/tools" class="fixed top-4 left-4 md:top-6 md:left-6 z-50 px-3 py-2 text-sm border border-cyan-400/50 bg-black/50 text-cyan-400 tracking-widest hover:bg-cyan-400/10 hover:border-cyan-400 transition-colors duration-300">{'<'} TOOLS</a>
    <div class="max-w-3xl mx-auto px-4 pt-20 pb-16">
      <div class="mb-8">
        <p class="text-cyan-400/40 text-xs tracking-widest mb-1">AOI TOOLS / 008</p>
        <h1 class="text-2xl tracking-widest text-cyan-400">CONTRAST CHECKER</h1>
        <p class="text-cyan-400/50 text-sm mt-1">WCAG コントラスト比を計算</p>
      </div>

      <div class="grid md:grid-cols-2 gap-4 mb-6">
        <!-- Foreground -->
        <div>
          <label class="text-xs tracking-widest text-cyan-400/60 block mb-2">FOREGROUND</label>
          <div class="flex gap-2 items-center">
            <input type="color" id="fg-picker" value="#ffffff" class="bg-black border border-cyan-400/30 h-10 w-16 cursor-pointer p-0.5" />
            <input type="text" id="fg-hex" value="#ffffff" maxlength="7" class="flex-1 bg-black border border-cyan-400/30 text-cyan-400/80 text-sm p-3 focus:outline-none focus:border-cyan-400/70 font-mono" />
          </div>
        </div>
        <!-- Background -->
        <div>
          <label class="text-xs tracking-widest text-cyan-400/60 block mb-2">BACKGROUND</label>
          <div class="flex gap-2 items-center">
            <input type="color" id="bg-picker" value="#000000" class="bg-black border border-cyan-400/30 h-10 w-16 cursor-pointer p-0.5" />
            <input type="text" id="bg-hex" value="#000000" maxlength="7" class="flex-1 bg-black border border-cyan-400/30 text-cyan-400/80 text-sm p-3 focus:outline-none focus:border-cyan-400/70 font-mono" />
          </div>
        </div>
      </div>

      <!-- Preview -->
      <div id="preview-box" class="w-full h-16 mb-6 border border-cyan-400/20 flex items-center justify-center text-lg" style="background-color: #000000; color: #ffffff;">
        Sample Text — サンプルテキスト
      </div>

      <!-- Ratio -->
      <div class="mb-6 text-center border border-cyan-400/20 p-4">
        <p class="text-xs tracking-widest text-cyan-400/40 mb-1">CONTRAST RATIO</p>
        <p class="text-4xl text-cyan-300" id="ratio">21.00 : 1</p>
      </div>

      <!-- WCAG Results -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px border border-cyan-400/20">
        <div class="bg-black p-4 text-center">
          <p class="text-xs text-cyan-400/40 tracking-widest mb-2">AA Normal</p>
          <p class="text-sm font-bold" id="aa-normal">PASS</p>
          <p class="text-xs text-cyan-400/30 mt-1">≥ 4.5</p>
        </div>
        <div class="bg-black p-4 text-center">
          <p class="text-xs text-cyan-400/40 tracking-widest mb-2">AA Large</p>
          <p class="text-sm font-bold" id="aa-large">PASS</p>
          <p class="text-xs text-cyan-400/30 mt-1">≥ 3.0</p>
        </div>
        <div class="bg-black p-4 text-center">
          <p class="text-xs text-cyan-400/40 tracking-widest mb-2">AAA Normal</p>
          <p class="text-sm font-bold" id="aaa-normal">PASS</p>
          <p class="text-xs text-cyan-400/30 mt-1">≥ 7.0</p>
        </div>
        <div class="bg-black p-4 text-center">
          <p class="text-xs text-cyan-400/40 tracking-widest mb-2">AAA Large</p>
          <p class="text-sm font-bold" id="aaa-large">PASS</p>
          <p class="text-xs text-cyan-400/30 mt-1">≥ 4.5</p>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  function hexToRgb(hex: string): [number, number, number] {
    const clean = hex.replace('#', '');
    if (clean.length !== 6) return [0, 0, 0];
    const bigint = parseInt(clean, 16);
    return [(bigint >> 16) & 255, (bigint >> 8) & 255, bigint & 255];
  }

  function getLuminance(hex: string): number {
    const rgb = hexToRgb(hex);
    const [r, g, b] = rgb.map(v => {
      const s = v / 255;
      return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4);
    });
    return 0.2126 * r + 0.7152 * g + 0.0722 * b;
  }

  function getContrastRatio(hex1: string, hex2: string): number {
    const l1 = getLuminance(hex1), l2 = getLuminance(hex2);
    return (Math.max(l1, l2) + 0.05) / (Math.min(l1, l2) + 0.05);
  }

  const fgPicker = document.getElementById('fg-picker') as HTMLInputElement;
  const bgPicker = document.getElementById('bg-picker') as HTMLInputElement;
  const fgHex = document.getElementById('fg-hex') as HTMLInputElement;
  const bgHex = document.getElementById('bg-hex') as HTMLInputElement;
  const previewBox = document.getElementById('preview-box')!;
  const ratioEl = document.getElementById('ratio')!;
  const aaNormal = document.getElementById('aa-normal')!;
  const aaLarge = document.getElementById('aa-large')!;
  const aaaNormal = document.getElementById('aaa-normal')!;
  const aaaLarge = document.getElementById('aaa-large')!;

  function setResult(el: Element, pass: boolean) {
    el.textContent = pass ? 'PASS' : 'FAIL';
    el.className = `text-sm font-bold ${pass ? 'text-green-400' : 'text-red-400'}`;
  }

  function update() {
    const fg = fgHex.value;
    const bg = bgHex.value;
    const fgValid = /^#[0-9a-fA-F]{6}$/.test(fg);
    const bgValid = /^#[0-9a-fA-F]{6}$/.test(bg);
    if (!fgValid || !bgValid) return;

    previewBox.style.color = fg;
    previewBox.style.backgroundColor = bg;

    const ratio = getContrastRatio(fg, bg);
    ratioEl.textContent = `${ratio.toFixed(2)} : 1`;

    setResult(aaNormal, ratio >= 4.5);
    setResult(aaLarge, ratio >= 3.0);
    setResult(aaaNormal, ratio >= 7.0);
    setResult(aaaLarge, ratio >= 4.5);
  }

  fgPicker.addEventListener('input', () => { fgHex.value = fgPicker.value; update(); });
  bgPicker.addEventListener('input', () => { bgHex.value = bgPicker.value; update(); });
  fgHex.addEventListener('input', () => { if (/^#[0-9a-fA-F]{6}$/.test(fgHex.value)) { fgPicker.value = fgHex.value; update(); } });
  bgHex.addEventListener('input', () => { if (/^#[0-9a-fA-F]{6}$/.test(bgHex.value)) { bgPicker.value = bgHex.value; update(); } });

  update();
</script>
