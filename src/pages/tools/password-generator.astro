---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Password Generator | AOI Tools">
  <main class="relative min-h-screen bg-black text-cyan-400 font-mono">
    <a href="/tools" class="fixed top-4 left-4 md:top-6 md:left-6 z-50 px-3 py-2 text-sm border border-cyan-400/50 bg-black/50 text-cyan-400 tracking-widest hover:bg-cyan-400/10 hover:border-cyan-400 transition-colors duration-300">{'<'} TOOLS</a>
    <div class="max-w-3xl mx-auto px-4 pt-20 pb-16">
      <div class="mb-8">
        <p class="text-cyan-400/40 text-xs tracking-widest mb-1">AOI TOOLS / 028</p>
        <h1 class="text-2xl tracking-widest text-cyan-400">PASSWORD GENERATOR</h1>
        <p class="text-cyan-400/50 text-sm mt-1">安全なパスワードを生成</p>
      </div>

      <!-- Length -->
      <div class="mb-5">
        <label class="text-xs tracking-widest text-cyan-400/60 block mb-2">LENGTH — <span id="len-val">16</span></label>
        <input id="length" type="range" min="8" max="64" value="16" class="w-full accent-cyan-400 cursor-pointer">
      </div>

      <!-- Options -->
      <div class="grid grid-cols-2 gap-2 mb-5">
        {[
          { id: 'opt-upper', label: '大文字 (A-Z)', checked: true },
          { id: 'opt-lower', label: '小文字 (a-z)', checked: true },
          { id: 'opt-num',   label: '数字 (0-9)',   checked: true },
          { id: 'opt-sym',   label: '記号 (!@#...)', checked: true },
        ].map(({ id, label, checked }) => (
          <label class="flex items-center gap-2 text-sm text-cyan-400/70 cursor-pointer">
            <input type="checkbox" id={id} checked={checked} class="accent-cyan-400"> {label}
          </label>
        ))}
      </div>

      <!-- Exclude chars -->
      <div class="mb-5">
        <label class="text-xs tracking-widest text-cyan-400/60 block mb-2">除外文字 (例: l0OI)</label>
        <input id="exclude" type="text" placeholder="除外したい文字を入力..."
          class="w-full bg-black border border-cyan-400/30 text-cyan-400/80 text-sm p-3 focus:outline-none focus:border-cyan-400/70 font-mono">
      </div>

      <!-- Count -->
      <div class="mb-5">
        <label class="text-xs tracking-widest text-cyan-400/60 block mb-2">生成数 (1-10)</label>
        <input id="count" type="number" min="1" max="10" value="1"
          class="w-32 bg-black border border-cyan-400/30 text-cyan-400/80 text-sm p-3 focus:outline-none focus:border-cyan-400/70 font-mono">
      </div>

      <div class="flex gap-3 mb-6">
        <button id="gen-btn" class="px-4 py-2 text-sm border border-cyan-400/60 bg-cyan-400/10 hover:bg-cyan-400/20 hover:border-cyan-400 transition-colors tracking-widest cursor-pointer">GENERATE</button>
        <button id="copy-all" class="px-4 py-2 text-sm border border-cyan-400/20 text-cyan-400/50 hover:border-cyan-400/50 hover:text-cyan-400/80 transition-colors tracking-widest cursor-pointer">COPY ALL</button>
      </div>

      <!-- Strength -->
      <div class="mb-4">
        <div class="flex gap-1 mb-1">
          <div id="s1" class="h-1 flex-1 bg-cyan-400/10 transition-all"></div>
          <div id="s2" class="h-1 flex-1 bg-cyan-400/10 transition-all"></div>
          <div id="s3" class="h-1 flex-1 bg-cyan-400/10 transition-all"></div>
          <div id="s4" class="h-1 flex-1 bg-cyan-400/10 transition-all"></div>
        </div>
        <p id="strength-label" class="text-xs text-cyan-400/40"></p>
      </div>

      <!-- Results -->
      <div id="results" class="space-y-2"></div>
    </div>
  </main>
</Layout>

<script>
  const UPPER = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const LOWER = 'abcdefghijklmnopqrstuvwxyz';
  const NUMS  = '0123456789';
  const SYMS  = '!@#$%^&*()-_=+[]{}|;:,.<>?';

  const lenSlider = document.getElementById('length') as HTMLInputElement;
  const lenVal    = document.getElementById('len-val')!;
  lenSlider.addEventListener('input', () => { lenVal.textContent = lenSlider.value; generate(); });

  function getCharset(): string {
    const exclude = (document.getElementById('exclude') as HTMLInputElement).value;
    let chars = '';
    if ((document.getElementById('opt-upper') as HTMLInputElement).checked) chars += UPPER;
    if ((document.getElementById('opt-lower') as HTMLInputElement).checked) chars += LOWER;
    if ((document.getElementById('opt-num')   as HTMLInputElement).checked) chars += NUMS;
    if ((document.getElementById('opt-sym')   as HTMLInputElement).checked) chars += SYMS;
    return [...chars].filter(c => !exclude.includes(c)).join('');
  }

  function makePassword(len: number, chars: string): string {
    if (!chars) return '';
    const arr = new Uint32Array(len);
    crypto.getRandomValues(arr);
    return [...arr].map(v => chars[v % chars.length]).join('');
  }

  function calcStrength(pwd: string): number {
    let score = 0;
    if (pwd.length >= 12) score++;
    if (pwd.length >= 16) score++;
    if (/[A-Z]/.test(pwd)) score++;
    if (/[a-z]/.test(pwd)) score++;
    if (/[0-9]/.test(pwd)) score++;
    if (/[^A-Za-z0-9]/.test(pwd)) score++;
    return Math.min(4, Math.floor(score * 4 / 6));
  }

  const strengthColors = ['bg-red-500','bg-yellow-500','bg-blue-400','bg-green-400'];
  const strengthLabels = ['WEAK','FAIR','STRONG','VERY STRONG'];

  function updateStrength(pwd: string) {
    const s = calcStrength(pwd);
    for (let i = 1; i <= 4; i++) {
      const el = document.getElementById(`s${i}`)!;
      el.className = `h-1 flex-1 transition-all ${i <= s ? strengthColors[s-1] : 'bg-cyan-400/10'}`;
    }
    document.getElementById('strength-label')!.textContent = pwd ? strengthLabels[s-1] ?? '' : '';
  }

  async function copyText(text: string, btn: HTMLElement) {
    await navigator.clipboard.writeText(text);
    const orig = btn.textContent;
    btn.textContent = 'Copied.';
    setTimeout(() => btn.textContent = orig, 1500);
  }

  function generate() {
    const len   = +lenSlider.value;
    const count = Math.min(10, Math.max(1, +(document.getElementById('count') as HTMLInputElement).value));
    const chars = getCharset();
    const pwds  = Array.from({ length: count }, () => makePassword(len, chars));
    const el    = document.getElementById('results')!;
    el.innerHTML = pwds.map((p, i) => `
      <div class="flex items-center gap-2 border border-cyan-400/20 p-2">
        <span class="flex-1 text-cyan-300 text-sm break-all" data-pwd="${i}">${p}</span>
        <button class="copy-one text-xs px-2 py-1 border border-cyan-400/20 text-cyan-400/50 hover:border-cyan-400/50 hover:text-cyan-400/80 transition-colors tracking-widest cursor-pointer shrink-0" data-i="${i}">COPY</button>
      </div>
    `).join('');
    el.querySelectorAll<HTMLElement>('.copy-one').forEach(btn => {
      btn.addEventListener('click', () => {
        const pwd = (el.querySelector(`[data-pwd="${btn.dataset.i}"]`) as HTMLElement).textContent ?? '';
        copyText(pwd, btn);
      });
    });
    if (pwds[0]) updateStrength(pwds[0]);
  }

  document.getElementById('gen-btn')!.addEventListener('click', generate);
  document.getElementById('copy-all')!.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLElement;
    const all = [...document.querySelectorAll<HTMLElement>('[data-pwd]')].map(el => el.textContent ?? '').join('\n');
    await copyText(all, btn);
  });
  ['opt-upper','opt-lower','opt-num','opt-sym','exclude','count'].forEach(id =>
    document.getElementById(id)!.addEventListener('input', generate));

  generate();
</script>
