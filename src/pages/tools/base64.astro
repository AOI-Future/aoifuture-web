---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="BASE64 | AOI Tools">
  <main class="relative min-h-screen bg-black text-cyan-400 font-mono">
    <a href="/tools" class="fixed top-4 left-4 md:top-6 md:left-6 z-50 px-3 py-2 text-sm border border-cyan-400/50 bg-black/50 text-cyan-400 tracking-widest hover:bg-cyan-400/10 hover:border-cyan-400 transition-colors duration-300">{'<'} TOOLS</a>
    <div class="max-w-3xl mx-auto px-4 pt-20 pb-16">
      <div class="mb-8">
        <p class="text-cyan-400/40 text-xs tracking-widest mb-1">AOI TOOLS / 006</p>
        <h1 class="text-2xl tracking-widest text-cyan-400">BASE64</h1>
        <p class="text-cyan-400/50 text-sm mt-1">テキストのBase64エンコード・デコード</p>
      </div>

      <div class="mb-4">
        <label class="text-xs tracking-widest text-cyan-400/60 block mb-2">INPUT</label>
        <textarea
          id="b64-input"
          class="w-full bg-black border border-cyan-400/30 text-cyan-400/80 text-sm p-3 focus:outline-none focus:border-cyan-400/70 font-mono h-32 resize-none"
          placeholder="テキストまたはBase64文字列を入力..."
        ></textarea>
      </div>

      <div class="flex gap-2 mb-4">
        <button id="encode-btn" class="px-4 py-2 text-sm border border-cyan-400/60 bg-cyan-400/10 hover:bg-cyan-400/20 hover:border-cyan-400 transition-colors tracking-widest cursor-pointer">ENCODE</button>
        <button id="decode-btn" class="px-4 py-2 text-sm border border-cyan-400/60 bg-cyan-400/10 hover:bg-cyan-400/20 hover:border-cyan-400 transition-colors tracking-widest cursor-pointer">DECODE</button>
        <button id="clear-btn" class="px-4 py-2 text-sm border border-cyan-400/20 text-cyan-400/50 hover:border-cyan-400/50 hover:text-cyan-400/80 transition-colors tracking-widest cursor-pointer">CLEAR</button>
      </div>

      <p id="error-msg" class="text-red-400 text-xs mb-2 hidden"></p>

      <div class="mb-4">
        <div class="flex items-center justify-between mb-2">
          <label class="text-xs tracking-widest text-cyan-400/60">OUTPUT</label>
          <button id="copy-btn" class="px-4 py-2 text-sm border border-cyan-400/60 bg-cyan-400/10 hover:bg-cyan-400/20 hover:border-cyan-400 transition-colors tracking-widest cursor-pointer">COPY</button>
        </div>
        <textarea
          id="b64-output"
          readonly
          class="w-full bg-black border border-cyan-400/20 text-cyan-400/80 text-sm p-3 font-mono h-32 resize-none"
        ></textarea>
        <p id="copy-feedback" class="text-xs text-cyan-400/40 mt-1 transition-opacity opacity-0">Copied.</p>
      </div>
    </div>
  </main>
</Layout>

<script>
  const b64Input = document.getElementById('b64-input') as HTMLTextAreaElement;
  const b64Output = document.getElementById('b64-output') as HTMLTextAreaElement;
  const errorMsg = document.getElementById('error-msg')!;
  const copyFeedback = document.getElementById('copy-feedback')!;
  const encodeBtn = document.getElementById('encode-btn')!;
  const decodeBtn = document.getElementById('decode-btn')!;
  const clearBtn = document.getElementById('clear-btn')!;
  const copyBtn = document.getElementById('copy-btn')!;

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorMsg.classList.remove('hidden');
  }

  function clearError() {
    errorMsg.textContent = '';
    errorMsg.classList.add('hidden');
  }

  encodeBtn.addEventListener('click', () => {
    clearError();
    try {
      b64Output.value = btoa(unescape(encodeURIComponent(b64Input.value)));
    } catch (e) {
      showError('エンコードに失敗しました: ' + String(e));
    }
  });

  decodeBtn.addEventListener('click', () => {
    clearError();
    try {
      b64Output.value = decodeURIComponent(escape(atob(b64Input.value)));
    } catch (e) {
      showError('デコードに失敗しました。有効なBase64文字列を入力してください。');
    }
  });

  clearBtn.addEventListener('click', () => {
    b64Input.value = '';
    b64Output.value = '';
    clearError();
  });

  copyBtn.addEventListener('click', () => {
    if (!b64Output.value) return;
    navigator.clipboard.writeText(b64Output.value).then(() => {
      copyFeedback.style.opacity = '1';
      setTimeout(() => { copyFeedback.style.opacity = '0'; }, 1500);
    });
  });
</script>
