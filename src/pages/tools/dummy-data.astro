---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Dummy Data | AOI Tools">
  <main class="relative min-h-screen bg-black text-cyan-400 font-mono">
    <a href="/tools" class="fixed top-4 left-4 md:top-6 md:left-6 z-50 px-3 py-2 text-sm border border-cyan-400/50 bg-black/50 text-cyan-400 tracking-widest hover:bg-cyan-400/10 hover:border-cyan-400 transition-colors duration-300">{'<'} TOOLS</a>
    <div class="max-w-3xl mx-auto px-4 pt-20 pb-16">
      <div class="mb-8">
        <p class="text-cyan-400/40 text-xs tracking-widest mb-1">AOI TOOLS / 025</p>
        <h1 class="text-2xl tracking-widest text-cyan-400">DUMMY DATA</h1>
        <p class="text-cyan-400/50 text-sm mt-1">日本語ダミーデータを生成</p>
      </div>

      <!-- Settings -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div>
          <label class="text-xs tracking-widest text-cyan-400/60 block mb-2">生成数</label>
          <input id="count" type="number" min="1" max="50" value="5"
            class="w-full bg-black border border-cyan-400/30 text-cyan-400/80 text-sm p-3 focus:outline-none focus:border-cyan-400/70 font-mono">
        </div>
        <div>
          <label class="text-xs tracking-widest text-cyan-400/60 block mb-2">フィールド選択</label>
          <div class="grid grid-cols-2 gap-1">
            {[
              { id: 'f-name', label: '氏名', checked: true },
              { id: 'f-kana', label: 'フリガナ', checked: true },
              { id: 'f-email', label: 'メール', checked: true },
              { id: 'f-phone', label: '電話番号', checked: true },
              { id: 'f-zip', label: '郵便番号', checked: false },
              { id: 'f-pref', label: '都道府県', checked: false },
              { id: 'f-birth', label: '生年月日', checked: false },
              { id: 'f-gender', label: '性別', checked: false },
            ].map(({ id, label, checked }) => (
              <label class="flex items-center gap-2 text-xs text-cyan-400/70 cursor-pointer">
                <input type="checkbox" id={id} checked={checked} class="accent-cyan-400">
                {label}
              </label>
            ))}
          </div>
        </div>
      </div>

      <div class="flex gap-3 mb-6">
        <button id="gen-btn" class="px-4 py-2 text-sm border border-cyan-400/60 bg-cyan-400/10 hover:bg-cyan-400/20 hover:border-cyan-400 transition-colors tracking-widest cursor-pointer">GENERATE</button>
        <button id="copy-json" class="px-4 py-2 text-sm border border-cyan-400/20 text-cyan-400/50 hover:border-cyan-400/50 hover:text-cyan-400/80 transition-colors tracking-widest cursor-pointer">COPY JSON</button>
        <button id="copy-csv" class="px-4 py-2 text-sm border border-cyan-400/20 text-cyan-400/50 hover:border-cyan-400/50 hover:text-cyan-400/80 transition-colors tracking-widest cursor-pointer">COPY CSV</button>
      </div>
      <p id="copy-msg" class="text-xs text-cyan-400/40 mb-3 opacity-0 transition-opacity">Copied.</p>

      <!-- Table -->
      <div id="table-wrap" class="hidden overflow-x-auto">
        <table id="result-table" class="border border-cyan-400/20 text-sm w-full">
          <thead id="thead"></thead>
          <tbody id="tbody"></tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<script>
  const lastNames = ['佐藤','鈴木','高橋','田中','伊藤','渡辺','山本','中村','小林','加藤','吉田','山田','佐々木','松本','井上','木村','林','斎藤','清水','山崎'];
  const firstNameM = ['翔','大輝','蓮','陸','悠斗','健太','拓海','大和','颯太','誠'];
  const firstNameF = ['葵','陽菜','凛','莉子','美咲','花','さくら','優奈','詩織','彩'];
  const lastKana = ['サトウ','スズキ','タカハシ','タナカ','イトウ','ワタナベ','ヤマモト','ナカムラ','コバヤシ','カトウ','ヨシダ','ヤマダ','ササキ','マツモト','イノウエ','キムラ','ハヤシ','サイトウ','シミズ','ヤマザキ'];
  const firstKanaM = ['ショウ','ダイキ','レン','リク','ユウト','ケンタ','タクミ','ヤマト','ソウタ','マコト'];
  const firstKanaF = ['アオイ','ハルナ','リン','リコ','ミサキ','ハナ','サクラ','ユウナ','シオリ','アヤ'];
  const domains = ['example.com','test.jp','dummy.co.jp','sample.ne.jp'];
  const prefs = ['北海道','青森県','岩手県','宮城県','秋田県','山形県','福島県','茨城県','栃木県','群馬県','埼玉県','千葉県','東京都','神奈川県','新潟県','富山県','石川県','福井県','山梨県','長野県','岐阜県','静岡県','愛知県','三重県','滋賀県','京都府','大阪府','兵庫県','奈良県','和歌山県','鳥取県','島根県','岡山県','広島県','山口県','徳島県','香川県','愛媛県','高知県','福岡県','佐賀県','長崎県','熊本県','大分県','宮崎県','鹿児島県','沖縄県'];

  function rand<T>(arr: T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }
  function randInt(min: number, max: number): number { return Math.floor(Math.random() * (max - min + 1)) + min; }
  function pad2(n: number): string { return String(n).padStart(2, '0'); }

  function generate(count: number, fields: Set<string>): Record<string, string>[] {
    return Array.from({ length: count }, () => {
      const isMale = Math.random() > 0.5;
      const lnIdx = randInt(0, lastNames.length - 1);
      const fnArr = isMale ? firstNameM : firstNameF;
      const fnKArr = isMale ? firstKanaM : firstKanaF;
      const ln = lastNames[lnIdx], lnK = lastKana[lnIdx];
      const fn = rand(fnArr), fnK = rand(fnKArr);
      const row: Record<string, string> = {};
      if (fields.has('f-name')) row['氏名'] = `${ln} ${fn}`;
      if (fields.has('f-kana')) row['フリガナ'] = `${lnK} ${fnK}`;
      if (fields.has('f-email')) {
        const local = (lnK + fnK).toLowerCase().replace(/[^a-z]/gi, '') || 'user';
        row['メール'] = `${local}${randInt(1,99)}@${rand(domains)}`;
      }
      if (fields.has('f-phone')) row['電話番号'] = `0${rand(['90','80','70'])}-${randInt(1000,9999)}-${randInt(1000,9999)}`;
      if (fields.has('f-zip')) row['郵便番号'] = `${randInt(100,999)}-${randInt(1000,9999)}`;
      if (fields.has('f-pref')) row['都道府県'] = rand(prefs);
      if (fields.has('f-birth')) {
        const y = randInt(1960, 2005), m = randInt(1,12), d = randInt(1,28);
        row['生年月日'] = `${y}/${pad2(m)}/${pad2(d)}`;
      }
      if (fields.has('f-gender')) row['性別'] = isMale ? '男' : '女';
      return row;
    });
  }

  let data: Record<string, string>[] = [];
  const copyMsg = document.getElementById('copy-msg')!;

  function flash(msg: string) {
    copyMsg.textContent = msg;
    copyMsg.style.opacity = '1';
    setTimeout(() => copyMsg.style.opacity = '0', 1500);
  }

  document.getElementById('gen-btn')!.addEventListener('click', () => {
    const count = Math.min(50, Math.max(1, +(document.getElementById('count') as HTMLInputElement).value));
    const fields = new Set(['f-name','f-kana','f-email','f-phone','f-zip','f-pref','f-birth','f-gender']
      .filter(id => (document.getElementById(id) as HTMLInputElement).checked));
    data = generate(count, fields);
    if (!data.length || !Object.keys(data[0]).length) return;
    const headers = Object.keys(data[0]);
    const thead = document.getElementById('thead')!;
    const tbody = document.getElementById('tbody')!;
    thead.innerHTML = `<tr>${headers.map(h => `<th class="bg-cyan-400/10 text-cyan-400/60 text-xs tracking-widest p-2 text-left border-b border-cyan-400/20">${h}</th>`).join('')}</tr>`;
    tbody.innerHTML = data.map(row => `<tr>${headers.map(h => `<td class="border-t border-cyan-400/10 text-cyan-400/70 p-2 text-xs">${row[h] ?? ''}</td>`).join('')}</tr>`).join('');
    document.getElementById('table-wrap')!.classList.remove('hidden');
  });

  document.getElementById('copy-json')!.addEventListener('click', async () => {
    await navigator.clipboard.writeText(JSON.stringify(data, null, 2));
    flash('JSON Copied.');
  });
  document.getElementById('copy-csv')!.addEventListener('click', async () => {
    if (!data.length) return;
    const headers = Object.keys(data[0]);
    const csv = [headers.join(','), ...data.map(row => headers.map(h => `"${row[h] ?? ''}"`).join(','))].join('\n');
    await navigator.clipboard.writeText(csv);
    flash('CSV Copied.');
  });
</script>
