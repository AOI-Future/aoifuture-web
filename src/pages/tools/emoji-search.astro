  let currentCategory = 'all';
  let currentSearch = '';

  const grid = document.getElementById('emoji-grid')!;
  const searchInput = document.getElementById('emoji-search') as HTMLInputElement;
  const copyFeedback = document.getElementById('copy-feedback')!;

  function renderEmojis() {
    const q = currentSearch.toLowerCase();
    const filtered = emojis.filter((e) => {
      const catMatch = currentCategory === 'all' || e.category === currentCategory;
      const searchMatch = !q || e.name.includes(q) || e.keywords.some((k) => k.includes(q)) || e.emoji === q;
      return catMatch && searchMatch;
    });

    grid.innerHTML = '';
    filtered.forEach((item) => {
      const btn = document.createElement('button');
      btn.textContent = item.emoji;
      btn.title = item.name;
      btn.className = 'relative text-2xl p-2 hover:bg-cyan-400/10 border border-transparent hover:border-cyan-400/20 transition-colors cursor-pointer flex items-center justify-center group';
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(item.emoji).then(() => {
          copyFeedback.textContent = `Copied ${item.emoji}`;
          copyFeedback.style.opacity = '1';
          setTimeout(() => { copyFeedback.style.opacity = '0'; }, 1500);
        });
      });
      grid.appendChild(btn);
    });
  }

  searchInput.addEventListener('input', () => {
    currentSearch = searchInput.value;
    renderEmojis();
  });

  document.querySelectorAll('.cat-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      currentCategory = (btn as HTMLElement).dataset.cat!;
      document.querySelectorAll('.cat-btn').forEach((b) => {
        b.classList.remove('border-cyan-400/40', 'text-cyan-400/60');
        b.classList.add('border-cyan-400/20', 'text-cyan-400/40');
      });
      btn.classList.remove('border-cyan-400/20', 'text-cyan-400/40');
      btn.classList.add('border-cyan-400/40', 'text-cyan-400/60');
      renderEmojis();
    });
  });

  renderEmojis();
</script>
