---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="EMOJI SEARCH | AOI Tools">
  <main class="relative min-h-screen bg-black text-cyan-400 font-mono">
    <a href="/tools" class="fixed top-4 left-4 md:top-6 md:left-6 z-50 px-3 py-2 text-sm border border-cyan-400/50 bg-black/50 text-cyan-400 tracking-widest hover:bg-cyan-400/10 hover:border-cyan-400 transition-colors duration-300">{'<'} TOOLS</a>
    <div class="max-w-3xl mx-auto px-4 pt-20 pb-16">
      <div class="mb-8">
        <p class="text-cyan-400/40 text-xs tracking-widest mb-1">AOI TOOLS / 023</p>
        <h1 class="text-2xl tracking-widest text-cyan-400">EMOJI SEARCH</h1>
        <p class="text-cyan-400/50 text-sm mt-1">絵文字をキーワードで検索してコピー</p>
      </div>

      <div class="mb-4">
        <input
          type="text"
          id="emoji-search"
          placeholder="search emoji..."
          class="w-full bg-black border border-cyan-400/30 text-cyan-400/80 text-sm p-3 focus:outline-none focus:border-cyan-400/70 font-mono"
        />
      </div>

      <div class="mb-4 flex flex-wrap gap-2">
        <button class="cat-btn active-cat px-3 py-1 text-xs border border-cyan-400/40 text-cyan-400/60 hover:border-cyan-400/70 transition-colors cursor-pointer" data-cat="all">All</button>
        <button class="cat-btn px-3 py-1 text-xs border border-cyan-400/20 text-cyan-400/40 hover:border-cyan-400/50 hover:text-cyan-400/60 transition-colors cursor-pointer" data-cat="smileys">Smileys</button>
        <button class="cat-btn px-3 py-1 text-xs border border-cyan-400/20 text-cyan-400/40 hover:border-cyan-400/50 hover:text-cyan-400/60 transition-colors cursor-pointer" data-cat="people">People</button>
        <button class="cat-btn px-3 py-1 text-xs border border-cyan-400/20 text-cyan-400/40 hover:border-cyan-400/50 hover:text-cyan-400/60 transition-colors cursor-pointer" data-cat="nature">Nature</button>
        <button class="cat-btn px-3 py-1 text-xs border border-cyan-400/20 text-cyan-400/40 hover:border-cyan-400/50 hover:text-cyan-400/60 transition-colors cursor-pointer" data-cat="food">Food</button>
        <button class="cat-btn px-3 py-1 text-xs border border-cyan-400/20 text-cyan-400/40 hover:border-cyan-400/50 hover:text-cyan-400/60 transition-colors cursor-pointer" data-cat="travel">Travel</button>
        <button class="cat-btn px-3 py-1 text-xs border border-cyan-400/20 text-cyan-400/40 hover:border-cyan-400/50 hover:text-cyan-400/60 transition-colors cursor-pointer" data-cat="objects">Objects</button>
        <button class="cat-btn px-3 py-1 text-xs border border-cyan-400/20 text-cyan-400/40 hover:border-cyan-400/50 hover:text-cyan-400/60 transition-colors cursor-pointer" data-cat="symbols">Symbols</button>
        <button class="cat-btn px-3 py-1 text-xs border border-cyan-400/20 text-cyan-400/40 hover:border-cyan-400/50 hover:text-cyan-400/60 transition-colors cursor-pointer" data-cat="flags">Flags</button>
      </div>

      <p id="copy-feedback" class="text-xs text-cyan-400/40 mb-2 transition-opacity opacity-0">Copied.</p>

      <div id="emoji-grid" class="grid grid-cols-8 md:grid-cols-12 gap-1">
      </div>
    </div>
  </main>
</Layout>

