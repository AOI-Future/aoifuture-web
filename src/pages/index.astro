---
import Layout from '../layouts/Layout.astro';
import LifeGame from '../components/LifeGame';
import Navigator from '../components/Navigator';
import AmbientSound from '../components/AmbientSound';
---

<Layout
  title="AOI Future | AI-native Solo Studio"
  description="作品とAIを含む仕事の仕組みをつくるAI-native solo studio / living laboratory。NICTIAは中心的なアーティストプロジェクトの一つです。"
>
  <main class="relative min-h-screen">
    <!-- Life Game Background -->
    <LifeGame client:load />

    <!-- Overlay Navigator -->
    <Navigator client:load />

    <!-- Ambient Sound Control -->
    <AmbientSound client:load />

    <!-- Center Content -->
    <div class="fixed inset-0 flex items-center justify-center pointer-events-none z-10">
      <div class="text-center">
        <h1 class="text-4xl md:text-6xl font-mono text-cyan-400/20 tracking-[0.3em] select-none">
          AOIFUTURE
        </h1>
        <p class="mt-4 text-sm text-cyan-400/10 font-mono tracking-widest">
          CREATING DIGITAL REALITIES
        </p>
      </div>
    </div>
  </main>
</Layout>
