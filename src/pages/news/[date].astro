---
import NewsEdition from '../../components/news/NewsEdition.astro';
import NewsLayout from '../../layouts/NewsLayout.astro';
import { loadNewsCatalog } from '../../lib/news/load-news';
import { getLatestReviewedEditionEvent } from '../../lib/news/load-news-events';
import { buildEditionMetadata } from '../../lib/news/metadata.mjs';
import type { NewsEdition as NewsEditionType } from '../../lib/news/types';

export const prerender = true;

export function getStaticPaths() {
  return loadNewsCatalog().editions.map((edition) => ({
    params: { date: edition.edition_date },
    props: {
      edition,
      latestReviewedAt: getLatestReviewedEditionEvent(edition.edition_id).published_at,
    },
  }));
}

interface Props {
  edition: NewsEditionType;
  latestReviewedAt: string;
}

const { edition, latestReviewedAt } = Astro.props;
const catalog = loadNewsCatalog();
---

<NewsLayout
  title={`${edition.title} | AOIFUTURE News`}
  description={edition.dek ?? edition.title}
  canonical={`https://aoifuture.com/news/${edition.edition_date}/`}
  jsonLd={buildEditionMetadata(edition, latestReviewedAt)}
>
  <NewsEdition edition={edition} contexts={catalog.contexts} />
</NewsLayout>
