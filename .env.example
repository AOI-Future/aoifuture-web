# Native consultation intake is opt-in. Keep false until provider checks pass.
CONSULTATION_NATIVE_FORM_ENABLED=false
CONSULTATION_ALLOWED_ORIGINS=https://aoifuture.com,https://www.aoifuture.com
PUBLIC_CONSULTATION_FALLBACK_URL=https://aoifuture.notion.site/6a828f1f8371416187ab544742734fcd?pvs=105

