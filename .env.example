# Shared native contact/consultation intake is opt-in. Keep false until provider checks pass.
CONSULTATION_NATIVE_FORM_ENABLED=false
CONSULTATION_ALLOWED_ORIGINS=https://aoifuture.com,https://www.aoifuture.com,https://nozaki.com,https://www.nozaki.com,https://wfhradio.tokyo,https://www.wfhradio.tokyo,https://dispatch.aoifuture.com
PUBLIC_CONSULTATION_FALLBACK_URL=https://aoifuture.notion.site/6a828f1f8371416187ab544742734fcd?pvs=105

# Managed Turnstile. Production balanced mode requires both keys and true.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
CONSULTATION_REQUIRE_TURNSTILE=false

# Atomic distributed abuse limiter (Upstash-compatible REST).
# Production balanced mode requires all three values and true. Generate a random 32+ byte hash secret.
CONSULTATION_RATE_LIMIT_REST_URL=
CONSULTATION_RATE_LIMIT_REST_TOKEN=
CONSULTATION_RATE_LIMIT_HASH_SECRET=
CONSULTATION_RATE_LIMIT_NAMESPACE=development
CONSULTATION_REQUIRE_DISTRIBUTED_LIMIT=false

# Never commit real values. Preview must use a separate data source.
NOTION_API_KEY=
NOTION_CONSULTATION_DATA_SOURCE_ID=
NOTION_API_VERSION=2025-09-03
